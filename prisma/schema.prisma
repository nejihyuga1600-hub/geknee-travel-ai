// Prisma schema for GeKnee travel app
// Database: PostgreSQL via Supabase
// Used by: NextAuth.js v5 for user accounts

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // pooled (port 6543) — used by the app
  directUrl = env("DIRECT_DATABASE_URL") // direct (port 5432) — used by migrations
}

generator client {
  provider = "prisma-client-js"
}

// ── NextAuth required models ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth users; bcrypt hash for email/password
  username      String?   @unique // chosen display handle e.g. @travelguy — lowercase, no spaces
  lastSeen      DateTime? // updated on presence ping — used for online status

  // ── Billing ────────────────────────────────────────────────────────────────
  plan                 String    @default("free") // "free" | "pro"
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  planExpiresAt        DateTime?

  // ── Usage tracking ─────────────────────────────────────────────────────────
  itineraryGenerations Int      @default(0)
  generationsResetAt   DateTime @default(now())

  // ── Email vault ────────────────────────────────────────────────────────────
  // Per-user random token used as the local part of a forwarding address
  // like vault-<token>@inbox.geknee.com. Lazily generated on first
  // settings view. Confidentiality matters: anyone holding the token can
  // forge inbound mail to this user, so we only print it to the owner.
  inboundEmailToken String? @unique

  accounts Account[]
  sessions Session[]
  trips    TripDraft[]
  tripFiles TripFile[]
  sentFriendRequests     Friendship[]   @relation("SentRequests")
  receivedFriendRequests Friendship[]   @relation("ReceivedRequests")
  notifications          Notification[]
  collectedMonuments     CollectedMonument[]
  completedMissions      CompletedMission[]
  tokenUsage             DailyTokenUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Trip drafts ───────────────────────────────────────────────────────────────

model TripDraft {
  id        String   @id @default(cuid())
  userId    String
  title     String
  location  String
  startDate String?
  endDate   String?
  nights    Int?
  style              String?  // JSON stringified preferences (from /plan/style)
  notes              String?
  itinerary          String?  // Full markdown itinerary text
  itineraryUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  files    TripFile[]
  bookings Booking[]
}

// ── Affiliate-partner conversion records ─────────────────────────────────────
// Populated by the Travelpayouts cron poller (and future partner webhooks).
// Each row = one tracked booking surfaced through a geknee outbound link.
// tripId is best-effort: encoded in the outbound link's sub_id and matched
// here when the partner returns the conversion. NULL when sub_id was lost
// or unparseable — we still want the row for revenue accounting.
model Booking {
  id              String   @id @default(cuid())
  tripId          String?
  userId          String?
  partner         String   // "travelpayouts" / future: "booking" / "expedia"
  partnerProgram  String?  // "Tiqets" / "Klook" / "Aviasales" / "Hotellook" / etc
  providerOrderId String   // partner-issued unique conversion id
  itemKind        String?  // hotel / activity / flight / insurance / car
  itemName        String?
  amount          Decimal? @db.Decimal(10, 2)
  payout          Decimal? @db.Decimal(10, 2)
  currency        String?
  status          String   // "pending" | "confirmed" | "cancelled" | "rejected"
  rawPayload      Json
  conversionAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trip TripDraft? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@unique([partner, providerOrderId])
  @@index([tripId])
  @@index([userId])
  @@index([partner, status])
}

// ── Trip File Vault ───────────────────────────────────────────────────────────

model TripFile {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  name      String   // original filename
  url       String   // Supabase Storage public URL
  storagePath String // path in bucket for deletion
  size      Int      // bytes
  tag       String   @default("other") // passport | booking | insurance | photo | other
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip TripDraft @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// ── Email vault ───────────────────────────────────────────────────────────────
// Idempotency record for the inbound-email pipeline. Postmark retries
// failed webhooks; we dedupe on RFC 822 Message-ID so re-deliveries
// don't double-file. Stored even when extraction fails so we never
// re-process a known-bad email.
model InboundMessage {
  id          String   @id @default(cuid())
  messageId   String   @unique // RFC 822 Message-ID header
  userId      String?  // null when token didn't resolve to a user
  status      String   // "received" | "extracted" | "filed" | "skipped" | "error"
  reason      String?  // free-text on skipped / error
  receivedAt  DateTime @default(now())
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String                        // recipient
  type      String                        // "friend_message" | "friend_request" | "trip_update"
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Monument Collection (gamification) ───────────────────────────────────────

model CollectedMonument {
  id          String   @id @default(cuid())
  userId      String
  monumentId  String   // e.g. "eiffelTower"
  skin        String   @default("default") // "default" | "gold" | "night" | "crystal" | etc.
  active      Boolean  @default(false) // true = this skin is displayed on the globe
  collectedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, monumentId, skin])
}

model CompletedMission {
  id          String   @id @default(cuid())
  userId      String
  monumentId  String
  missionId   String   // e.g. "eiffelTower_night"
  photoUrl    String?  // compressed photo for photo-verified missions (base64 data URL)
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, missionId])
}

// ── Friends ───────────────────────────────────────────────────────────────────

model Friendship {
  id       String @id @default(cuid())
  userId   String // who sent the request
  friendId String // who received it
  status   String @default("pending") // pending | accepted

  createdAt DateTime @default(now())

  user   User @relation("SentRequests",     fields: [userId],   references: [id], onDelete: Cascade)
  friend User @relation("ReceivedRequests", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

// ── Claude API token usage tracking ──────────────────────────────────────────

model DailyTokenUsage {
  userId       String
  date         String            // "2026-04-15" UTC
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  callCount    Int      @default(0)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
}
